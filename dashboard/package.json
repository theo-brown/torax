{
  "name": "torax-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "bundle": "npm run build && node scripts/bundle.mjs",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" index.html vite.config.ts \"scripts/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" index.html vite.config.ts \"scripts/*.mjs\""
  },
  "dependencies": {
    "plotly.js-basic-dist-min": "^3.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "prettier": "^3.9.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
